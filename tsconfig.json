{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "node20",
    "target": "es2020",
    "types": [],
    "declaration": true,
    "stripInternal": true,
    // "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    // "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
